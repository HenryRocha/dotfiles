#!/usr/bin/xonsh

# ==========================================================
# Autostart
# ==========================================================

# ==========================================================
# BSPWM
# ==========================================================
mainMonitor = "DP-4"
externalMonitor1 = "HDMI-0"

if !(xrandr -q | grep "HDMI-0 connected" >> /dev/null).returncode != 0:
    ![bspc monitor @(mainMonitor) -d 1 2 3 4 5 6 7 8 9 0]
else:
    ![bspc monitor @(mainMonitor) -d 1 2 3 4 5]
    ![bspc monitor @(externalMonitor1) -d 6 7 8 9 0]

![bspc config border_width 2]
![bspc config window_gap 8]

![bspc config focus_follows_pointer true]
![bspc config split_ratio 0.52]
![bspc config borderless_monocle true]
![bspc config gapless_monocle true]

![bspc rule -r "*"]
![bspc rule -a Alacritty desktop=^3 follow=on]
![bspc rule -a Spacefm desktop=^4 follow=on]
![bspc rule -a Pavucontrol state=floating floating=on]
![bspc rule -a "code-oss" desktop=^2 follow=on]
![bspc rule -a Nitrogen state=floating floating=on]
![bspc rule -a "Microsoft Teams - Preview" desktop=^7 follow=on]
